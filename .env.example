# Anthropic (LLM primário)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (LLM fallback — tier grátis em https://aistudio.google.com/apikey)
GEMINI_API_KEY=...

# CNPJá API (https://cnpja.com)
CNPJA_API_KEY=...

# Certidões fiscais via API (Infosimples) — opcional. Sem token, use upload de PDF.
# Conta + token em https://infosimples.com. Confirme os caminhos das consultas
# (federal/estadual/municipal/FGTS/trabalhista) na doc da sua conta.
INFOSIMPLES_TOKEN=...

# Postgres (fase 2 — base local RFB)
DATABASE_URL=postgresql://user:password@localhost:5432/licita_forense
